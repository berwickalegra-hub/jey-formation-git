# ─── Server (Next.js API Routes + Server Actions) ──────────────────────
# Copy to .env at the repo root (or `frontend/.env.local`) and fill in real values.

# Neon pooled connection — runtime queries only.
# The "-pooler" hostname routes through Neon's PgBouncer in transaction mode.
# `connection_limit=1` is REQUIRED on serverless: each Vercel function instance
# opens its own pool, and per-instance multi-connection pools exhaust Neon's
# ceiling under moderate concurrency.
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/dbname?pgbouncer=true&connection_limit=1&pool_timeout=15&sslmode=require"

# Direct (non-pooled) connection — REQUIRED for `prisma migrate deploy`.
# The pooler exhausts on long-lived migrations and breaks prepared statements.
# Without DIRECT_URL set, migrations time out or fail mid-run.
DIRECT_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Vercel Cron auth shared secret. Generate with: openssl rand -base64 32
# Required by /api/cron/* routes (Phase 5). Single shared secret across all crons.
CRON_SECRET=""

# JWT signing secret. Generate with: openssl rand -base64 48
# Must be at least 32 chars. Anything starting with "change-me", "secret", "test"…
# is rejected at boot.
JWT_SECRET=""

# AES-256-GCM encryption key for sensitive blob fields (currently unused in
# Phase 1; needed once you store integration tokens / OAuth refresh tokens).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=""

# Cookie name prefix. All auth cookies are named "${COOKIE_PREFIX}-token",
# "${COOKIE_PREFIX}-refresh", "${COOKIE_PREFIX}-csrf". Change per app so a
# dev sharing localhost across two starters doesn't clobber sessions.
COOKIE_PREFIX="app"

# Public origin URL — used for CORS allowlist + OAuth callback construction.
# Comma-separate ALLOWED_ORIGINS if you serve from multiple domains.
APP_URL="http://localhost:3000"
# ALLOWED_ORIGINS="https://example.com,https://www.example.com"

# Cookie domain for production (e.g. ".example.com" so cookies are shared
# across www.example.com and api.example.com). Leave empty for localhost dev.
# COOKIE_DOMAIN=""

# Node environment. The logger redacts PII when this is "production" or any
# unknown value (fail-safe). Leave unset / "development" locally.
# NODE_ENV=development

# ─── Upstash Redis ─────────────────────────────────────────────────────
# Optional in dev — without these the rate limiter falls back to an
# in-memory store (logged as a warning at boot). Required in production.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ─── Google OAuth (Sign in with Google) ────────────────────────────────
# Get these from https://console.cloud.google.com/apis/credentials
# (OAuth 2.0 Client ID, type "Web application").
# Authorized redirect URI must match GOOGLE_REDIRECT_URI exactly.
# Without these, /api/auth/oauth/google/* routes are inert (404'd).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/oauth/google/callback"

# ─── Phase 3 — payments (Bictorys, Senegalese mobile money) ────────────
# Without these, /api/orders, /api/withdrawals, /api/webhooks/bictorys
# are inert. Auth + uploads still work.
BICTORYS_API_KEY=""
BICTORYS_PRIVATE_KEY=""              # required only for payouts
BICTORYS_API_URL="https://api.bictorys.com"
BICTORYS_WEBHOOK_SECRET=""
BICTORYS_MERCHANT_SECRET_CODE=""     # required only for payouts

# Optional — marketplace commission rate in basis points (600 = 6%, 800 = 8%).
# Leave empty to skip commission computation.
COMMISSION_RATE_BP=""

# Dev-only — bypass webhook signature verification.
# NEVER set in production.
# DEV_BYPASS_WEBHOOK_VERIFY="1"

# ─── Phase 3 — withdrawal guards (defaults safe) ───────────────────────
# All optional. Defaults: positive amount required + balance check ON,
# no max/daily/cooldown/PIN. See README "Withdrawals — financial guards".
WITHDRAWAL_MIN_AMOUNT="1"               # min withdrawal in smallest unit
WITHDRAWAL_MAX_AMOUNT=""                # cap per withdrawal; empty = unlimited
WITHDRAWAL_DAILY_LIMIT=""               # cap on sum per 24h; empty = unlimited
WITHDRAWAL_COOLDOWN_HOURS="0"           # min hours between withdrawals
WITHDRAWAL_REQUIRE_PIN="0"              # 1/true → require PIN on every withdrawal
WITHDRAWAL_BALANCE_CHECK="1"            # 0/false → disable balance check (default ENABLED)

# ─── Sentry (error reporting + tracing) ────────────────────────────────
# Optional everywhere. Without SENTRY_DSN, the Sentry SDKs become no-ops
# (no events sent, no perf overhead).
#
# Server-side DSN:
SENTRY_DSN=""
# SENTRY_ENVIRONMENT="production"            # defaults to NODE_ENV
# SENTRY_RELEASE="myapp@1.2.3"               # set by your CI for source-map matching
# SENTRY_TRACES_SAMPLE_RATE="0.1"            # 0.0–1.0 — default 0 (off)
#
# Frontend (browser) DSN — separate Sentry project recommended so client
# events don't pollute server-side dashboards.
NEXT_PUBLIC_SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_ENVIRONMENT="production"
# NEXT_PUBLIC_SENTRY_RELEASE="myapp@1.2.3"
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE="0.1"
# NEXT_PUBLIC_SENTRY_REPLAYS_SAMPLE_RATE="0"  # session replay opt-in (costly)
#
# Source-map upload (CI only). Without these the build still succeeds but
# stack traces won't be symbolicated in Sentry.
# SENTRY_ORG=""
# SENTRY_PROJECT=""
# SENTRY_AUTH_TOKEN=""

# ─── Browser-exposed (public) ───────────────────────────────────────────
# These are exposed in the browser bundle. Must be prefixed NEXT_PUBLIC_.
# In a monolith the API is same-origin, so there's no API base URL to set —
# the browser hits /api/* on the same host that served the page.
NEXT_PUBLIC_COOKIE_PREFIX="app"

# ─────────────────────────────────────────────────────────────────
# Phase 1 — Auth tunables
# All values are per-fork overridable. Defaults (shown) are
# production-safe per CONTEXT.md decision IDs (D-06, D-07, D-08,
# D-10, D-13).
# ─────────────────────────────────────────────────────────────────

# Minimum password length (D-10, NIST 800-63B aligned).
AUTH_PASSWORD_MIN_LENGTH=10

# Verification code TTL in minutes (D-06). Codes are 8-char Crockford
# alphanumeric, single-use (consumed via VerificationCode.usedAt).
AUTH_VERIFICATION_TTL_MIN=15

# Failed-login lockout (D-07, AUTH-10).
# After AUTH_LOCKOUT_THRESHOLD failures within AUTH_LOCKOUT_DURATION_MIN
# minutes, the account is locked out for AUTH_LOCKOUT_DURATION_MIN minutes.
# Backed by Redis sliding-window counter (memory fallback in dev).
AUTH_LOCKOUT_THRESHOLD=5
AUTH_LOCKOUT_DURATION_MIN=15

# Per-email rate limits (D-08, AUTH-10). Keyed on lower-cased email.
# Falls back to per-IP when email is missing (parse failure / malformed body).
AUTH_LOGIN_RATE_LIMIT_MAX=10              # 10 / 15 min per email
AUTH_SIGNUP_RATE_LIMIT_MAX=5              # 5 / 1 hour per email
AUTH_FORGOT_RATE_LIMIT_MAX=3              # 3 / 1 hour per email
AUTH_RESET_RATE_LIMIT_MAX=5               # 5 / 15 min per email
AUTH_RESEND_VERIFY_RATE_LIMIT_MAX=3       # 3 / 1 hour per email (reserved for future resend endpoint)
AUTH_VERIFY_RATE_LIMIT_MAX=5              # 5 / 15 min per email

# HIBP haveibeenpwned password check (D-13). Opt-in.
# Set to "1" to enable. Default OFF.
# When enabled, signup / reset-password / change-password reject
# passwords found in known breaches via k-anonymity (first 5 chars of
# SHA-1 sent to api.pwnedpasswords.com — full password and full hash
# never leave the server). Fail-open on network error (logs warn).
PASSWORD_HIBP_CHECK=

# Email rate-limiter behaviour when Upstash is unreachable.
# Default OFF (fail-open) — the limiter logs a warn and lets the request
# through so a Redis blip doesn't take auth offline. In production with
# real abuse pressure you probably want fail-closed (return 429). Set to
# "1" to enable. (REVIEW.md WR-07.)
AUTH_RATE_LIMIT_FAIL_CLOSED=

# /api/auth/forgot-password wall-clock floor (ms). Pads each response so
# user-exists vs. no-user paths are timing-indistinguishable, defending
# against email-enumeration timing attacks (REVIEW.md CR-01).
# 350ms is the production-safe default. Set to "0" in tests so the suite
# doesn't add 350ms per test case.
AUTH_FORGOT_TARGET_LATENCY_MS=350

